generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String          @id @default(uuid())
  email      String          @unique
  password   String
  fullName   String          @map("full_name")
  phone      String?
  role       Role
  disability DisabilityInfo?
  parents    Json?
  type       UserType

  applicantInfo ApplicantInfo?
  studentInfo   StudentInfo?
  graduateInfo  GraduateInfo?
  organization  Organization?
  agreements    Agreement[]

  reviewsAsAuthor Review[] @relation("ReviewAuthor")
  reviewsAsTarget Review[] @relation("ReviewTarget")
  reviewsByUserId Review[] @relation("UserReviewsByUserId")

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  Certificate Certificate[]

  @@map("user")
}

model ApplicantInfo {
  id             String  @id @default(uuid())
  user           User    @relation(fields: [userId], references: [id])
  userId         String  @unique @map("user_id")
  department     String?
  specialization String?

  @@map("applicantInfo")
}

model StudentInfo {
  id               String     @id @default(uuid())
  user             User       @relation(fields: [userId], references: [id])
  userId           String     @unique @map("user_id")
  subdivision      String?
  educationLevel   String?    @map("education_level")
  course           Int?
  educationForm    String?    @map("education_form")
  major            String?
  department       String?
  group            String?
  mainProfessions  String[]   @map("main_professions")
  extraProfessions String[]   @map("extra_professions")
  practices        Practice[]
  jobs             Job[]

  certificates Certificate[]

  @@map("studentInfo")
}

model GraduateInfo {
  id               String        @id @default(uuid())
  userId           String        @unique @map("user_id")
  user             User          @relation(fields: [userId], references: [id])
  mainProfessions  String[]      @map("main_professions")
  extraProfessions String[]      @map("extra_professions")
  jobs             Job[]
  certificates     Certificate[]

  @@map("graduateInfo")
}

model DisabilityInfo {
  id          String  @id @default(uuid())
  user        User    @relation(fields: [userId], references: [id])
  userId      String  @unique @map("user_id")
  group       String
  type        String
  documentUrl String? @map("document_url")

  @@map("disabilyInfo")
}

model Organization {
  id                 String  @id @default(uuid())
  userId             String  @unique @map("user_id")
  user               User    @relation(fields: [userId], references: [id])
  shortName          String  @map("short_name")
  fullName           String  @map("full_name")
  description        String?
  website            String?
  address            String?
  inn                String  @unique
  kpp                String
  representativeName String  @map("representative_name")
  position           String
  phone              String
  email              String
  socialLinks        Json?   @map("social_links")
  documentUrl        String? @map("document_url")

  isConfirm Boolean @default(false)

  practices Practice[]
  jobs      Job[]
  reviews   Review[]

  @@map("organization")
}

model Practice {
  id             String       @id @default(uuid())
  type           String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id")
  city           String
  professions    String[]
  availableFor   String[]     @map("available_for")
  description    String?

  agreements    Agreement[]
  reviews       Review[]
  StudentInfo   StudentInfo? @relation(fields: [studentInfoId], references: [id])
  studentInfoId String?      @map("student_info_id")

  @@map("practice")
}

model Job {
  id             String       @id @default(uuid())
  title          String
  experience     String?
  salary         String?
  format         String?
  city           String
  professions    String[]
  availableFor   String[]     @map("available_for")
  description    String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id")

  agreements     Agreement[]
  reviews        Review[]
  StudentInfo    StudentInfo?  @relation(fields: [studentInfoId], references: [id])
  studentInfoId  String?       @map("student_info_id")
  GraduateInfo   GraduateInfo? @relation(fields: [graduateInfoId], references: [id])
  graduateInfoId String?       @map("graduate_info_id")

  @@map("job")
}

model Agreement {
  id     String  @id @default(uuid())
  user   User    @relation(fields: [userId], references: [id])
  userId String  @map("user_id")
  goal   String?
  status Status

  practice   Practice? @relation(fields: [practiceId], references: [id])
  practiceId String?   @map("practice_id")

  job   Job?    @relation(fields: [jobId], references: [id])
  jobId String? @map("job_id")

  @@map("agreement")
}

model Review {
  id             String        @id @default(uuid())
  fromUser       User          @relation("ReviewAuthor", fields: [fromUserId], references: [id])
  fromUserId     String        @map("from_user_id")
  toOrganization Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?       @map("organization_id")
  toUser         User?         @relation("ReviewTarget", fields: [toUserId], references: [id])
  toUserId       String?       @map("to_user_id")
  text           String
  user           User?         @relation("UserReviewsByUserId", fields: [userId], references: [id])
  userId         String?       @map("user_id")
  Practice       Practice?     @relation(fields: [practiceId], references: [id])
  practiceId     String?       @map("practice_id")
  Job            Job?          @relation(fields: [jobId], references: [id])
  jobId          String?       @map("job_id")

  @@map("review")
}

model Certificate {
  id             String        @id @default(uuid())
  url            String
  name           String
  owner          User          @relation(fields: [userId], references: [id])
  userId         String        @map("user_id")
  StudentInfo    StudentInfo?  @relation(fields: [studentInfoId], references: [id])
  studentInfoId  String?       @map("student_info_id")
  GraduateInfo   GraduateInfo? @relation(fields: [graduateInfoId], references: [id])
  graduateInfoId String?       @map("graduate_info_id")

  @@map("certificate")
}

model File {
  id        String   @id @default(uuid())
  name      String
  type      String
  size      Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("file")
}

enum Role {
  APPLICANT
  STUDENT
  GRADUATE
  ORGANIZATION
  ADMIN
  MODERATOR
  STAFF
}

enum UserType {
  INDIVIDUAL
  ORGANIZATION
}

enum Status {
  PENDING
  ACCEPTED
  DECLINED
}
