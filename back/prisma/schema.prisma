generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(uuid())
  email           String          @unique
  password        String
  fullName        String          @map("full_name")
  phone           String?
  role            Role
  parents         Json?
  type            UserType
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  agreements      Agreement[]
  applicantInfo   ApplicantInfo?
  Certificate     Certificate[]
  disability      DisabilityInfo?
  graduateInfo    GraduateInfo?
  organization    Organization?
  reviewsAsAuthor Review[]        @relation("ReviewAuthor")
  reviewsAsTarget Review[]        @relation("ReviewTarget")
  reviewsByUserId Review[]        @relation("UserReviewsByUserId")
  studentInfo     StudentInfo?

  @@map("user")
}

model ApplicantInfo {
  id             String  @id @default(uuid())
  userId         String  @unique @map("user_id")
  department     String?
  specialization String?
  user           User    @relation(fields: [userId], references: [id])

  @@map("applicantInfo")
}

model StudentInfo {
  id               String        @id @default(uuid())
  userId           String        @unique @map("user_id")
  subdivision      String?
  educationLevel   String?       @map("education_level")
  course           Int?
  educationForm    String?       @map("education_form")
  major            String?
  department       String?
  group            String?
  mainProfessions  String[]      @map("main_professions")
  extraProfessions String[]      @map("extra_professions")
  certificates     Certificate[]
  jobs             Job[]
  practices        Practice[]
  user             User          @relation(fields: [userId], references: [id])

  @@map("studentInfo")
}

model GraduateInfo {
  id               String        @id @default(uuid())
  userId           String        @unique @map("user_id")
  mainProfessions  String[]      @map("main_professions")
  extraProfessions String[]      @map("extra_professions")
  certificates     Certificate[]
  user             User          @relation(fields: [userId], references: [id])
  jobs             Job[]

  @@map("graduateInfo")
}

model DisabilityInfo {
  id          String  @id @default(uuid())
  userId      String  @unique @map("user_id")
  group       String
  type        String
  documentUrl String? @map("document_url")
  user        User    @relation(fields: [userId], references: [id])

  @@map("disabilyInfo")
}

model Organization {
  id                 String     @id @default(uuid())
  userId             String     @unique @map("user_id")
  shortName          String     @map("short_name")
  fullName           String     @map("full_name")
  description        String?
  website            String?
  address            String?
  inn                String     @unique
  kpp                String
  representativeName String     @map("representative_name")
  position           String
  phone              String
  email              String
  socialLinks        Json?      @map("social_links")
  documentUrl        String?    @map("document_url")
  isConfirm          Boolean    @default(false)
  jobs               Job[]
  user               User       @relation(fields: [userId], references: [id])
  practices          Practice[]
  reviews            Review[]

  @@map("organization")
}

model Practice {
  id             String         @id @default(uuid())
  type           String
  organizationId String         @map("organization_id")
  city           String
  professions    String[]
  availableFor   String[]       @map("available_for")
  description    String?
  studentInfoId  String?        @map("student_info_id")
  status         PracticeStatus @default(DRAFT)
  agreements     Agreement[]
  organization   Organization   @relation(fields: [organizationId], references: [id])
  StudentInfo    StudentInfo?   @relation(fields: [studentInfoId], references: [id])
  reviews        Review[]

  @@map("practice")
}

model Job {
  id             String        @id @default(uuid())
  title          String
  experience     String?
  salary         String?
  format         String?
  city           String
  professions    String[]
  availableFor   String[]      @map("available_for")
  description    String?
  organizationId String        @map("organization_id")
  studentInfoId  String?       @map("student_info_id")
  graduateInfoId String?       @map("graduate_info_id")
  agreements     Agreement[]
  GraduateInfo   GraduateInfo? @relation(fields: [graduateInfoId], references: [id])
  organization   Organization  @relation(fields: [organizationId], references: [id])
  StudentInfo    StudentInfo?  @relation(fields: [studentInfoId], references: [id])
  reviews        Review[]

  @@map("job")
}

model Agreement {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  goal       String?
  status     Status
  practiceId String?   @map("practice_id")
  jobId      String?   @map("job_id")
  job        Job?      @relation(fields: [jobId], references: [id])
  practice   Practice? @relation(fields: [practiceId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@map("agreement")
}

model Review {
  id             String        @id @default(uuid())
  fromUserId     String        @map("from_user_id")
  organizationId String?       @map("organization_id")
  toUserId       String?       @map("to_user_id")
  text           String
  userId         String?       @map("user_id")
  practiceId     String?       @map("practice_id")
  jobId          String?       @map("job_id")
  fromUser       User          @relation("ReviewAuthor", fields: [fromUserId], references: [id])
  Job            Job?          @relation(fields: [jobId], references: [id])
  toOrganization Organization? @relation(fields: [organizationId], references: [id])
  Practice       Practice?     @relation(fields: [practiceId], references: [id])
  toUser         User?         @relation("ReviewTarget", fields: [toUserId], references: [id])
  user           User?         @relation("UserReviewsByUserId", fields: [userId], references: [id])

  @@map("review")
}

model Certificate {
  id             String        @id @default(uuid())
  url            String
  name           String
  userId         String        @map("user_id")
  studentInfoId  String?       @map("student_info_id")
  graduateInfoId String?       @map("graduate_info_id")
  GraduateInfo   GraduateInfo? @relation(fields: [graduateInfoId], references: [id])
  StudentInfo    StudentInfo?  @relation(fields: [studentInfoId], references: [id])
  owner          User          @relation(fields: [userId], references: [id])

  @@map("certificate")
}

model File {
  id        String   @id @default(uuid())
  name      String
  type      String
  size      Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("file")
}

enum Role {
  APPLICANT
  STUDENT
  GRADUATE
  ORGANIZATION
  ADMIN
  MODERATOR
  STAFF
}

enum UserType {
  INDIVIDUAL
  ORGANIZATION
}

enum Status {
  PENDING
  ACCEPTED
  DECLINED
}

enum PracticeStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
  ARCHIVED
}
